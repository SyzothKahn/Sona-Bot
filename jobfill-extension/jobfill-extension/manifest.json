{
  "manifest_version": 3,
  "name": "JobFill",
  "version": "0.4.0",
  "description": "Kevin's personal job application autofill tool.",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "scripting"]
}
